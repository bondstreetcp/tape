# tape.env — the compute container's environment. Copy to `tape.env` and fill in the values, or just
# copy your existing dev `.env.local` and ADD the VERCEL_DEPLOY_HOOK line at the bottom.
# NAMES ONLY here (safe to commit); the real file with values is chmod 600 and NEVER committed.
# Optional keys can be omitted — the matching step logs "not configured — skipping" and moves on.

# ── Required: R2 (the data store — hydrate before / upload after every tick) ──────────────────────
LAKE_S3_ENDPOINT=            # https://<account-id>.r2.cloudflarestorage.com
LAKE_S3_BUCKET=
LAKE_S3_KEY_ID=
LAKE_S3_SECRET=

# ── Required: trigger the Vercel redeploy after data uploads (Vercel → Settings → Git → Deploy Hooks)
VERCEL_DEPLOY_HOOK=

# ── LLM + data-source keys (feeds that need one skip cleanly if it's absent) ──────────────────────
OPENROUTER_API_KEY=          # GLM/Gemini via OpenRouter — desk note, confluence, guidance, overnight, …
GEMINI_API_KEY=              # mover catalysts + OGE trades (grounded Q&A / OCR)
FRED_API_KEY=                # macro (yield curve, inflation, credit)
SIMFIN_API_KEY=              # margins backfill
ALPHAVANTAGE_API_KEY=        # margins backfill (capped ~25/day)
OPENFIGI_API_KEY=            # optional — 13F CUSIP→ticker (keyless tier works, just slower)

# ── Optional: local LLM (route the nightly extraction fleet to the EPYC/3090 box instead of cloud) ─
# Set all three to shift the mechanical-extraction jobs (ipo, corp-events, guidance, overnight-
# filings, biotech, policy, fed, catalyst-vol) to a local vLLM server; any local failure falls back
# to OpenRouter automatically. PRO judgment + live /api routes always stay cloud. See docs/SETUP-local-llm.md.
LLM_LOCAL_BASE_URL=          # http://<epyc-lan-ip>:8000/v1  (or a tunnel host)
LLM_LOCAL_MODEL=             # the model name exactly as vLLM serves it, e.g. Qwen/Qwen2.5-72B-Instruct-AWQ
LLM_LOCAL_API_KEY=           # the vLLM --api-key token

# ── Optional: alerts (SHELVED for beta — leave blank; the step skips if the tables don't exist) ───
RESEARCH_DATABASE_URL=

# ── Optional: weekly binary-events digest delivery (blank = it just logs, no send) ────────────────
DIGEST_WEBHOOK_URL=          # Slack/Discord/ntfy incoming webhook
ALERT_WEBHOOK_URL=           # fallback channel for the digest + the Ops-alerts watchdog
RESEND_API_KEY=              # email delivery (Resend)
DIGEST_EMAIL_TO=
DIGEST_EMAIL_FROM=
SITE_URL=                    # https://… for the board link in the digest
