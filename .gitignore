# data/ is NO LONGER committed — it lives in Cloudflare R2, hydrated at BUILD time by
# scripts/data-from-r2.ts (via `npm run vercel-build`). The nightly job regenerates data/, uploads it
# to R2 (scripts/data-to-r2.ts), and triggers a Vercel deploy. Keeping bulk, churning data OUT of git
# history is the whole point (docs/DATA-ON-R2.md). Local dev: `npm run data-from-r2` pulls the current
# tree from R2 (needs LAKE_S3_* in .env.local).
data/
_*.html
_*.json
_*.csv

# Licensed research corpus — never commit (raw PDFs + extracted/derived data)
data/.research/

# Research lake — Parquet lives in R2 (or a local ./lake for dev), NOT the repo. Keeping bulk,
# frequently-rewritten data OUT of git history is the whole point (see docs/RESEARCH-LAKE.md).
lake/
sql/views_local.sql
