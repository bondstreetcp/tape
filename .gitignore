# NOTE: data/ is intentionally TRACKED so Vercel ships the market-data snapshot.
# Refresh the deployed data with: npm run refresh-data && git commit -am "data" && git push
# (Vercel's runtime filesystem is read-only, so the data must be in the repo.)
data/iwv-holdings.*
_*.html
_*.json
_*.csv

# Licensed research corpus — never commit (raw PDFs + extracted/derived data)
data/.research/

# Research lake — Parquet lives in R2 (or a local ./lake for dev), NOT the repo. Keeping bulk,
# frequently-rewritten data OUT of git history is the whole point (see docs/RESEARCH-LAKE.md).
lake/
sql/views_local.sql
